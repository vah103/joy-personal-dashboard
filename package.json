{
  "name": "joy-personal-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply joy-dashboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply joy-dashboard --remote"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2"
  },
  "devDependencies": {
    "@fontsource/instrument-sans": "^5.2.8",
    "@fontsource/newsreader": "^5.2.8",
    "@fontsource/quicksand": "^5.2.8",
    "wrangler": "^4.113.0"
  }
}
